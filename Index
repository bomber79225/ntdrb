<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>R幣換算器</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        input::-webkit-outer-spin-button,
        input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        input[type=number] {
            -moz-appearance: textfield;
        }
        /* 避免長文字換行 */
        .no-wrap {
            white-space: nowrap;
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center p-4">

    <div class="bg-white w-full max-w-md rounded-[2.5rem] shadow-2xl overflow-hidden border border-gray-100">
        <!-- 表頭區域 -->
        <div class="bg-indigo-600 pt-10 pb-8 px-6 text-center text-white">
            <h1 class="text-3xl font-bold tracking-tight">R幣換算器</h1>
            <p class="text-indigo-100 mt-2 text-sm opacity-80">自訂匯率，即時雙向換算</p>
        </div>

        <div class="p-6 space-y-6">
            <!-- 匯率設定區 (修正後的版本) -->
            <div class="bg-indigo-50/50 p-5 rounded-3xl border border-indigo-100">
                <div class="flex items-center justify-between mb-3 px-1">
                    <label class="text-xs font-bold text-indigo-900 uppercase tracking-widest">匯率設定</label>
                    <span class="text-[10px] font-bold text-indigo-400 bg-white px-2 py-1 rounded-lg shadow-sm border border-indigo-50">FIXED RATIO</span>
                </div>
                
                <div class="flex items-center bg-white border-2 border-indigo-100 rounded-2xl px-4 py-3 focus-within:border-indigo-500 transition-all shadow-sm">
                    <span class="text-gray-500 font-medium no-wrap mr-3">1 台幣 =</span>
                    <input type="number" id="rateInput" value="1" step="any"
                        class="flex-1 focus:outline-none text-indigo-600 font-bold text-xl w-full bg-transparent"
                        placeholder="請輸入">
                    <span class="text-gray-400 font-bold no-wrap ml-2">R 幣</span>
                </div>
            </div>

            <!-- 轉換輸入區 -->
            <div class="space-y-4 relative">
                <!-- 台幣輸入 -->
                <div class="group">
                    <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-1.5 ml-2">台幣 (TWD)</label>
                    <div class="relative">
                        <input type="number" id="twdInput" 
                            class="w-full bg-gray-50 border-2 border-gray-100 group-focus-within:border-indigo-500 group-focus-within:bg-white rounded-2xl px-5 py-4 text-2xl font-semibold transition-all outline-none"
                            placeholder="0.00">
                        <div class="absolute right-5 top-1/2 -translate-y-1/2 text-gray-300 font-medium">NT$</div>
                    </div>
                </div>

                <!-- 切換按鈕圖示 (置中懸浮) -->
                <div class="flex justify-center -my-3 relative z-10">
                    <div class="bg-white p-2 rounded-full shadow-lg border border-gray-100 text-indigo-500">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" />
                        </svg>
                    </div>
                </div>

                <!-- R 幣輸入 -->
                <div class="group">
                    <label class="block text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-1.5 ml-2">R 幣 (RC)</label>
                    <div class="relative">
                        <input type="number" id="rInput" 
                            class="w-full bg-gray-50 border-2 border-gray-100 group-focus-within:border-indigo-500 group-focus-within:bg-white rounded-2xl px-5 py-4 text-2xl font-semibold transition-all outline-none"
                            placeholder="0.00">
                        <div class="absolute right-5 top-1/2 -translate-y-1/2 text-gray-300 font-bold">R</div>
                    </div>
                </div>
            </div>

            <!-- 清除與資訊區 -->
            <div class="flex flex-col space-y-4 pt-4">
                <button id="clearBtn" class="w-full py-4 bg-gray-900 text-white rounded-2xl font-bold hover:bg-black active:scale-[0.97] transition-all shadow-xl">
                    清空數值
                </button>
                <div class="text-center pb-2">
                    <p id="infoText" class="text-xs font-medium text-gray-400">目前匯率：1 TWD = 1.00 R幣</p>
                </div>
            </div>
        </div>
    </div>

    <script>
        const rateInput = document.getElementById('rateInput');
        const twdInput = document.getElementById('twdInput');
        const rInput = document.getElementById('rInput');
        const clearBtn = document.getElementById('clearBtn');
        const infoText = document.getElementById('infoText');

        function formatVal(num) {
            if (isNaN(num) || num === 0) return '';
            // 四捨五入到小數點後四位，並移除無用的 0
            return Math.round((num + Number.EPSILON) * 10000) / 10000;
        }

        function updateFromTWD() {
            const rate = parseFloat(rateInput.value) || 0;
            const twd = parseFloat(twdInput.value) || 0;
            if (rate > 0) {
                rInput.value = formatVal(twd * rate);
            } else {
                rInput.value = '';
            }
        }

        function updateFromR() {
            const rate = parseFloat(rateInput.value) || 0;
            const rVal = parseFloat(rInput.value) || 0;
            if (rate > 0) {
                twdInput.value = formatVal(rVal / rate);
            } else {
                twdInput.value = '';
            }
        }

        function updateInfo() {
            const rate = rateInput.value || '0';
            infoText.textContent = `目前匯率：1 TWD = ${rate} R幣`;
            updateFromTWD();
        }

        twdInput.addEventListener('input', updateFromTWD);
        rInput.addEventListener('input', updateFromR);
        rateInput.addEventListener('input', updateInfo);
        
        clearBtn.addEventListener('click', () => {
            twdInput.value = '';
            rInput.value = '';
        });

        // 手機端友善：點擊輸入框自動全選
        [rateInput, twdInput, rInput].forEach(input => {
            input.addEventListener('focus', (e) => e.target.select());
        });
    </script>
</body>
</html>

